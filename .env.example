# LLM provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Model name for the selected provider
# Anthropic examples: claude-haiku-4-5-20251001, claude-sonnet-4-6
# OpenAI examples:    gpt-4o-mini, gpt-4o
LLM_MODEL=claude-haiku-4-5-20251001

# Anthropic API key — required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key — required when LLM_PROVIDER=openai (also: pip install openai)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL connection for the rate limiter DB (read-only — rate_limit_log, app_info, rate_limit_plan)
RATE_LIMITER_DB=postgresql://app_user:app_password@localhost:5432/rate_limiter

# PostgreSQL connection for the agent DB (read-write — agent_results, orchestrator_results, baseline_memory, eval_run_results)
AGENT_DB_URL=postgresql://app_user:app_password@localhost:5432/rate_limiter_agents

# How often the agent pipeline runs (in minutes). Default: 15
AGENT_INTERVAL_MINUTES=15

# Comma-separated list of allowed CORS origins. Default: localhost only.
CORS_ORIGINS=http://localhost:8000,http://localhost:3000
